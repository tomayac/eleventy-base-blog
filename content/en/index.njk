---
locale: en
title: home
eleventyNavigation:
  key: Home-en
  title: home
  order: 1
permalink: /en/index.html
numberOfLatestPostsToShow: 3
---
{% set postsCount = collections.posts | filterByLocale(locale) | length %}
{% set latestPostsCount = postsCount | min(numberOfLatestPostsToShow) %}
<h1>{{ 'latest_posts' | plural(latestPostsCount, locale) }}</h1>

{% set postslist = collections.posts | filterByLocale(locale) | head(-1 * numberOfLatestPostsToShow) %}
{% set postslistCounter = postsCount %}
{% include "postslist.njk" %}

{% set morePosts = postsCount - numberOfLatestPostsToShow %}
{% if morePosts > 0 %}
<p>{{ 'more_posts' | plural(morePosts, locale) | safe }}</p>
{% endif %}
