---
layout: layouts/create.njk
eleventyExcludeFromCollections: true
---
<h1>Create Blog Post</h1>

<div class="editor-container">
	<div class="editor-sidebar">
		<div class="sidebar-header">
			<h2>Drafts</h2>
			<button id="new-draft-btn" title="New Draft">+</button>
		</div>
		<ul id="drafts-list"></ul>
		<div class="sidebar-footer">
			<details class="settings-details">
				<summary>⚙️ Settings</summary>
				<div class="settings-content">
					<label class="ai-toggle-label">
						✨ AI Features
						<input type="checkbox" switch id="ai-features-toggle" checked>
					</label>
					<hr>
					<div class="form-group">
						<label for="gh-token">
							GitHub Token
							<a href="https://github.com/settings/personal-access-tokens/new?name=Core-loop+token&description=Write%20code%20and%20push%20it%20to%20main%21&contents=write&pull_requests=write" target="_blank" rel="noopener" class="help-icon" title="How to get a GitHub Token">ⓘ</a>
						</label>
						<input type="password" id="gh-token" placeholder="ghp_xxxxxxxxxxxx">
					</div>
					<div class="form-group">
						<label for="gh-owner">GitHub Username</label>
						<input type="text" id="gh-owner" placeholder="username">
					</div>
					<div class="form-group">
						<label for="gh-repo">Repository Name</label>
						<input type="text" id="gh-repo" placeholder="my-blog">
					</div>
					<hr>
					<button type="button" id="reset-app-btn" class="danger">🗑️ Reset Application</button>
				</div>
			</details>
		</div>
	</div>

	<div class="editor-main">
		<form id="post-form">
			<div class="form-group">
				<label for="post-title">Title</label>
				<div class="input-with-action">
					<input type="text" id="post-title" required placeholder="My Awesome Post">
					<button type="button" id="ai-suggest-title-btn" style="display: none;" title="Suggest title using AI">✨</button>
				</div>
			</div>

			<div class="form-group">
				<label for="post-description">Description</label>
				<div class="input-with-action">
					<input type="text" id="post-description" placeholder="A brief summary of the post">
					<button type="button" id="ai-suggest-description-btn" style="display: none;" title="Suggest description using AI">✨</button>
				</div>
			</div>

			<div class="form-group">
				<label for="post-date">Date</label>
				<input type="date" id="post-date" required>
			</div>

			<div class="form-group">
				<label for="tag-input">Tags</label>
				<div class="tag-container">
					<div id="tag-pills" class="tag-pills"></div>
					<div class="tag-input-wrapper">
						<input type="text" id="tag-input" placeholder="Add tag and press Enter...">
						<button type="button" id="ai-suggest-tags-btn" style="display: none;" title="Suggest tags using AI">✨</button>
					</div>
				</div>
				<input type="hidden" id="post-tags">
			</div>

			<div class="form-group">
				<label for="post-content">Content (Markdown)</label>
				<p class="field-hint">💡 Tip: You can drag and drop images directly into the editor or use the button below to place them at the current cursor position.</p>
				<div class="editor-header-actions">
					<button type="button" id="upload-btn">📂 Add Images</button>
				</div>
				<div id="drop-zone">
					<textarea id="post-content" rows="20" placeholder="Write your post here... Use Markdown for **bold**, *italics*, [links](url), - bullets, or ```code blocks```."></textarea>
				</div>
				<input type="file" id="file-input" multiple accept="image/*" style="display: none;">
			</div>

			<div class="form-group ai-writer-section" style="display: none;">
				<label for="ai-writer-input">Help me write</label>
				<p class="field-hint">💡 Enter a few bullet points or a teaser, and AI will expand it into a full post.</p>
				<div class="input-with-action">
					<textarea id="ai-writer-input" rows="3" placeholder="e.g., - My trip to Tokyo&#10;- Visited Tsukiji market&#10;- Amazing sushi at 5am"></textarea>
					<button type="button" id="ai-writer-btn" style="display: none;" title="Expand into a full post">✨</button>
				</div>
				<div class="editor-footer-actions">
					<div id="ai-status" style="font-size: 0.7rem; color: #666; display: none;">
						<progress id="ai-download-progress" value="0" max="100" style="width: 100px;"></progress>
						<span id="ai-status-text">Ready</span>
					</div>
				</div>
			</div>
		</form>

		<div class="editor-actions">
			<button id="copy-btn">📋 Copy Markdown</button>
			<button id="download-btn">💾 Save (.zip)</button>
			<button id="github-pr-btn">🚀 Create PR</button>
		</div>
	</div>

	<div class="editor-preview">
		<h2>Preview</h2>
		<div id="preview-content" class="markdown-body"></div>
	</div>
</div>

<dialog id="alert-dialog">
	<form method="dialog">
		<p id="alert-message"></p>
		<div class="dialog-actions">
			<button class="primary">OK</button>
		</div>
	</form>
</dialog>

<dialog id="confirm-dialog">
	<form method="dialog">
		<p id="confirm-message"></p>
		<div class="dialog-actions">
			<button value="cancel" class="secondary">Cancel</button>
			<button value="confirm" class="danger">Delete</button>
		</div>
	</form>
</dialog>
